NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=https://your-domain.com

# ── LLM brain ────────────────────────────────────────────────────────────────
# Choose the provider that powers search + the stylist. All are OpenAI-compatible.
# LLM_PROVIDER: groq (default) | deepseek | kimi
LLM_PROVIDER=deepseek

# DeepSeek (recommended) — get a key at https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1   # optional override
# DEEPSEEK_CHAT_MODEL=deepseek-chat               # optional override

# Groq (fallback / default provider)
GROQ_API_KEY=your-groq-api-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=llama-3.1-8b-instant

# Kimi / Moonshot (optional alternative)
# MOONSHOT_API_KEY=your-moonshot-api-key
# MOONSHOT_CHAT_MODEL=kimi-k2-0711-preview

# Optional generic overrides — point at ANY OpenAI-compatible endpoint:
# LLM_BASE_URL=...
# LLM_API_KEY=...
# LLM_CHAT_MODEL=...
# LLM_TIMEOUT_MS=22000

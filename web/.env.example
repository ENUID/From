NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=https://your-domain.com

# AI text model — OpenRouter (https://openrouter.ai/keys), not Groq directly.
# Groq periodically retires hosted open models on short notice (it happened to
# llama-3.1-8b-instant / llama-3.3-70b-versatile / llama-4-scout in June 2026);
# OpenRouter proxies many open models (DeepSeek, Qwen, Llama, etc.) behind one
# stable API, so swapping models is an env var change, not a redeploy.
# No credit card required — the key alone is enough to use the free (":free")
# models the code defaults to below.
OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# "Smart" tier — tool-calling, search planning, Fabrics stylist heavy path.
# OPENROUTER_SMART_MODEL=deepseek/deepseek-chat-v3.1:free
# "Fast" tier — chitchat routing, rerank, descriptions, shipping, memory. Defaults
# to the smart model if unset; point it at something cheaper once you've picked one.
# OPENROUTER_FAST_MODEL=deepseek/deepseek-chat-v3.1:free
# Vision FALLBACK only (Gemini below is primary).
# OPENROUTER_VISION_MODEL=meta-llama/llama-4-maverick:free
# Verify these model IDs still exist at https://openrouter.ai/models before relying
# on the defaults — adjust here if a model gets renamed/retired, no code change needed.
# NOTE: OpenRouter's free tier is capped account-wide (all ":free" models combined)
# at 20 req/min and 50 req/day with $0 credit, or 1000/day once you've added $10 of
# credit (one-time, doesn't need to be spent — just raises the free-tier ceiling).

# Vision-classified product image ordering (model shot first, packshot last).
# Set to "off" to fall back to the filename/aspect heuristic. Default: on.
# IMAGE_ORDER_VISION=on

# Gemini — powers Fabrics stylist (free tier at aistudio.google.com)
GOOGLE_AI_API_KEY=your-google-ai-studio-key
# GEMINI_STYLIST_MODEL=gemini-2.0-flash

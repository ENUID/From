{
  "framework": "nextjs",
  "buildCommand": "if [ -n \"$CONVEX_DEPLOY_KEY\" ]; then npx convex deploy --cmd 'npm run build'; else npm run build; fi",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/style-signals",
      "schedule": "0 6 */2 * *"
    },
    {
      "path": "/api/cron/brand-health",
      "schedule": "0 5 * * *"
    }
  ]
}

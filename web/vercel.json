{
  "framework": "nextjs",
  "buildCommand": "if [ \"$VERCEL_ENV\" = \"production\" ] && [ -n \"$CONVEX_DEPLOY_KEY\" ]; then npx convex deploy --typecheck disable || true; fi; npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/style-signals",
      "schedule": "0 6 */2 * *"
    },
    {
      "path": "/api/cron/brand-health",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/quality-feedback",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/learning-analyst",
      "schedule": "0 8 * * 1"
    }
  ]
}

{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "web/.next",
  "framework": "nextjs",
  "installCommand": "npm install",
  "crons": [
    { "path": "/api/cron/brand-health", "schedule": "0 8 * * *" },
    { "path": "/api/cron/style-signals", "schedule": "0 6 */2 * *" },
    { "path": "/api/cron/quality-feedback", "schedule": "30 5 * * *" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "from.enuid.com" }],
      "destination": "https://discern.enuid.com/:path*",
      "permanent": true
    }
  ]
}
